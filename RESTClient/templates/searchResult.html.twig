{% extends 'base.html.twig' %}

{% block content %}
<h3 class="mb-3">Search Results</h3>

{% if list is empty %}
    <div class="alert alert-warning">No matching records found.</div>
{% else %}
<table class="table table-bordered table-striped">
    <thead class="table-dark">
        <tr>
            <th>ID</th>
            <th>Name</th>
            <th>Platform</th>
            <th>Category</th>
            <th>Image</th>
        </tr>
    </thead>
    <tbody>
    {% for item in list %}
        <tr>
            <td>{{ item.id }}</td>
            <td>{{ item.name }}</td>
            <td>{{ item.platform }}</td>
            <td>{{ item.category }}</td>
            <td><img src="static/photos/{{ item.filename }}" width="80"></td>
        </tr>
    {% endfor %}
    </tbody>
</table>
{% endif %}
{% endblock %}