{% extends 'base.html.twig' %}

{% block content %}
<h3 class="mb-3">All Game Records</h3>

{% if list is empty %}
<div class="alert alert-info">No records found.</div>
{% else %}
<table class="table table-bordered table-striped">
    <thead class="table-dark">
        <tr>
            <th>ID</th>
            <th>Name</th>
            <th>Platform</th>
            <th>Subscription</th>
            <th>Category</th>
            <th>Image</th>
        </tr>
    </thead>
    <tbody>
    {% for item in list %}
        <tr>
            <td>{{ item.id }}</td>
            <td>{{ item.name }}</td>
            <td>{{ item.platform }}</td>
            <td>{{ item.monthly_subscription }}</td>
            <td>{{ item.category }}</td>
            <td>
                <img src="static/photos/{{ item.filename }}" width="80" height="auto">
            </td>
        </tr>
    {% endfor %}
    </tbody>
</table>
{% endif %}
{% endblock %}